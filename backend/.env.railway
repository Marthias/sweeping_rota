# Railway Environment Variables
# These should be set in Railway dashboard, but here's a template

NODE_ENV=production
PORT=3000

# Database (set in Railway MySQL plugin)
DB_HOST=${{ MYSQLHOST }}
DB_PORT=${{ MYSQLPORT }}
DB_USER=${{ MYSQLUSER }}
DB_PASSWORD=${{ MYSQLPASSWORD }}
DB_NAME=${{ MYSQLDATABASE }}

# JWT Secret (generate a strong one)
JWT_SECRET=your_production_jwt_secret_key_here_change_this
